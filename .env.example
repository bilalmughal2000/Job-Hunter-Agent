# ─────────────────────────────────────────────────────────────
# AI Job Hunter — environment variables
# Copy to `.env` and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database (Phase 2)
DATABASE_URL=postgresql://jobhunter:jobhunter@localhost:5432/jobhunter?schema=public

# Cache / queues (optional)
REDIS_URL=redis://localhost:6379

# AI (Phase 5)
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Auth (Phase 6)
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Notifications (Phase 8)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM="AI Job Hunter <noreply@example.com>"

# CORS
CORS_ORIGIN=http://localhost:4200

# Resume uploads (Phase 4)
UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=5242880
