# ─────────────────────────────────────────────────────────────
# AI Job Hunter — environment variables
# Copy to `.env` and fill in. NEVER commit the real .env.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Database (Phase 2)
DATABASE_URL=postgresql://jobhunter:jobhunter@localhost:5432/jobhunter?schema=public

# Cache / queues (optional)
REDIS_URL=redis://localhost:6379

# AI (Phase 5). `heuristic` = no key, offline. `openai-compatible` = any
# OpenAI-compatible endpoint (OpenAI / Groq / Gemini / OpenRouter / Ollama).
AI_PROVIDER=heuristic
# Groq (free, no card):   https://api.groq.com/openai/v1     + llama-3.3-70b-versatile
# Gemini (free):          https://generativelanguage.googleapis.com/v1beta/openai/ + gemini-2.0-flash
# Ollama (local, no key): http://localhost:11434/v1          + any pulled model
AI_BASE_URL=https://api.openai.com/v1
AI_API_KEY=
AI_MODEL=gpt-4o-mini
AI_TIMEOUT_MS=30000

# Auth (Phase 6) — REQUIRED for /auth and /applications. Passwords are hashed
# with Node's built-in scrypt (no dependency); tokens signed with jsonwebtoken.
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Notifications (Phase 8)
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASSWORD=
EMAIL_FROM="AI Job Hunter <noreply@example.com>"

# CORS
CORS_ORIGIN=http://localhost:4200

# Resume uploads (Phase 4)
UPLOAD_DIR=uploads
UPLOAD_MAX_BYTES=5242880
